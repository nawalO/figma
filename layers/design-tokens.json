{
  "colors": {
    "background": {
      "primary": "#0B1117",
      "secondary": "#161B22",
      "tertiary": "#21262D"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#8B949E",
      "accent": "#58A6FF"
    },
    "interactive": {
      "button_active": "#0969DA",
      "button_hover": "#1F6FEB",
      "button_disabled": "#30363D"
    },
    "borders": {
